digraph MedLexer {
  rankdir=LR;
  node [shape=box, style=filled, fillcolor=lightblue, fontname=Helvetica];
  HOSPITAL [label="HOSPITAL"];
  PACIENTES [label="PACIENTES (12)"];
  MEDICOS [label="MEDICOS (5)"];
  CITAS [label="CITAS (12)"];
  DIAGNOSTICOS [label="DIAGNOSTICOS"];
  HOSPITAL -> PACIENTES;
  HOSPITAL -> MEDICOS;
  HOSPITAL -> CITAS;
  HOSPITAL -> DIAGNOSTICOS;
  PACIENTES -> CITAS;
  MEDICOS -> CITAS;
  CITAS -> DIAGNOSTICOS;
}
